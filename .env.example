# PulseDesk Comment-to-Ticket Triage - Environment Configuration Template
# 
# Copy this file to .env or .env.local and fill in your actual values.
# DO NOT commit .env or .env.local to git (they are in .gitignore).
# 
# For local development:
#   cp .env.example .env
#   (then edit .env with your actual values)

# ===========================
# Hugging Face Configuration
# ===========================

# Your Hugging Face API token
# Get it from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_TOKEN=your_hf_token_here

# Model ID to use for comment analysis
# Examples:
#   - google/flan-t5-base (baseline, older but stable)
#   - openai/gpt-oss-20b:novita (Novita provider)
#   - mistralai/Mistral-7B-Instruct-v0.2 (strong instruction following)
HUGGINGFACE_MODEL=openai/gpt-oss-20b:novita

# Hugging Face inference endpoint base URL
# Default: https://router.huggingface.co/hf-inference
HUGGINGFACE_BASE_URL=https://router.huggingface.co/hf-inference

# Request timeout in milliseconds
# Increase if you get frequent timeouts (HF service is slow)
# Default: 25000 (25 seconds)
HUGGINGFACE_TIMEOUT_MS=25000

# ===========================
# Processing Queue Settings
# ===========================

# Polling interval for comment processing in milliseconds
# Default: 250 (checks every 250ms for pending comments)
# PROCESSING_POLL_DELAY_MS=250

# Maximum number of analysis attempts before marking as FAILED
# Default: 3
# PROCESSING_RETRY_MAX_ATTEMPTS=3

# Delay between retries in milliseconds
# Default: 10000 (10 seconds)
# PROCESSING_RETRY_DELAY_MS=10000

# ===========================
# Rate Limiting
# ===========================

# Maximum requests allowed per window
# Default: 120
# RATE_LIMIT_REQUESTS_PER_WINDOW=120

# Time window in seconds
# Default: 60 (allows 120 req/min by default)
# RATE_LIMIT_WINDOW_SECONDS=60

# ===========================
# Database
# ===========================

# H2 database file location (file-based persistence)
# Data persists between restarts at: ./data/pulsedesk.mv.db
# (Customization usually not needed for development)
# SPRING_DATASOURCE_URL=jdbc:h2:file:./data/pulsedesk;MODE=PostgreSQL;DB_CLOSE_DELAY=-1

# ===========================
# Server
# ===========================

# Server port
# Default: 8080
# SERVER_PORT=8080

# ===========================
# Notes
# ===========================
#
# 1. If HUGGINGFACE_API_TOKEN is not set, the app runs in HEURISTIC-ONLY mode
#    (no AI classification, keyword-based fallback only).
#
# 2. Some models may be blocked by your provider/region/account restrictions.
#    Test connectivity with: python -m huggingface_hub.cli.hf model-info google/flan-t5-base
#
# 3. For production, use .env.local and keep it out of version control.
#
# 4. All values here are optional and have sensible defaults.
